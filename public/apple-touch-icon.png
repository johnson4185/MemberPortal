<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 180 180">
  <defs>
    <linearGradient id="appleGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background with rounded corners -->
  <rect width="180" height="180" rx="40" fill="url(#appleGradient)"/>
  
  <!-- Shield icon -->
  <path d="M90 45 L130 60 L130 95 Q130 120 90 145 Q50 120 50 95 L50 60 Z" 
        fill="white" 
        stroke="white" 
        stroke-width="3"/>
  
  <!-- Internal shield detail -->
  <path d="M90 63 L115 73 L115 98 Q115 115 90 130 Q65 115 65 98 L65 73 Z" 
        fill="#3b82f6" 
        opacity="0.3"/>
  
  <!-- Checkmark -->
  <path d="M78 93 L86 101 L103 81" 
        stroke="white" 
        stroke-width="6" 
        fill="none" 
        stroke-linecap="round" 
        stroke-linejoin="round"/>
  
  <!-- Connection dots -->
  <circle cx="68" cy="120" r="4" fill="white" opacity="0.9"/>
  <circle cx="90" cy="130" r="4" fill="white" opacity="0.9"/>
  <circle cx="112" cy="120" r="4" fill="white" opacity="0.9"/>
  
  <!-- Connection lines -->
  <line x1="68" y1="120" x2="90" y2="130" stroke="white" stroke-width="2.5" opacity="0.7"/>
  <line x1="90" y1="130" x2="112" y2="120" stroke="white" stroke-width="2.5" opacity="0.7"/>
</svg>
